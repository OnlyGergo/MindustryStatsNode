# ===========================================
# SHARED CONFIGURATION (All Services)
# ===========================================

# Application Environment
NODE_ENV=production
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mindustry_stats
DB_USER=postgres
DB_PASSWORD=your_password_here

# Valkey (Redis) Configuration
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_DB=0
VALKEY_KEY_PREFIX=mindustry:

# ===========================================
# SERVICE-SPECIFIC CONFIGURATION
# ===========================================

# Server Discovery Service
# 24 hours in production, 1 hour in dev
SERVER_LIST_INTERVAL_MS=86400000

# Server Collector Service

# Number of concurrent server queries
COLLECTION_CONCURRENCY=8
# Timeout for UDP queries
MINDUSTRY_TIMEOUT_MS=1000
# Seconds to wait when polling queues
QUEUE_POLL_TIMEOUT=5

# Server Processor Service

# Hours of history to keep
MAX_HISTORY_HOURS=36
# Maximum history points (36 hours * 24 points/hour)
MAX_HISTORY_POINTS=864

# API Service
API_PORT=3000
# Set to specific domain in production
CORS_ORIGIN=*

# WebSocket Service
WS_PORT=3001
WS_PATH=/ws

# ===========================================
# DEVELOPMENT OVERRIDES
# ===========================================
# Uncomment and modify for development environment

# NODE_ENV=development
# LOG_LEVEL=debug
# SERVER_LIST_INTERVAL_MS=3600000  # 1 hour in development
# COLLECTION_CONCURRENCY=4  # Lower concurrency for development
# CORS_ORIGIN=http://localhost:5173  # Vite dev server
