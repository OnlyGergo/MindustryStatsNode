# ===========================================
# SHARED CONFIGURATION
# ===========================================

# Application Environment
NODE_ENV=production
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mindustry_stats
DB_USER=postgres
DB_PASSWORD=your_password_here

# ===========================================
# SERVICE-SPECIFIC CONFIGURATION
# ===========================================

# Server Discovery
# 24 hours in production, 1 hour in dev
SERVER_LIST_INTERVAL_MS=86400000
# 5 minutes between collection cycles
DATA_COLLECTION_INTERVAL_MS=300000

# Server Collection
# Number of concurrent server queries (defaults to CPU cores * 1.5)
COLLECTION_CONCURRENCY=8
# Timeout for UDP queries
MINDUSTRY_TIMEOUT_MS=1000
# Seconds to wait when polling queues
QUEUE_POLL_TIMEOUT=5

# Server Processor
# Hours of history to keep
MAX_HISTORY_HOURS=36
# Maximum history points (36 hours * 24 points/hour)
MAX_HISTORY_POINTS=864

# API & WebSocket Service
# Both services run on the same port (WebSocket available at /ws path)
PORT=3000
# Set to specific domain in production
CORS_ORIGIN=*
# WebSocket path
WS_PATH=/ws
# Max graph points, buckets are calculated to match
GRAPH_MAX_POINTS=168

# ===========================================
# DEVELOPMENT OVERRIDES
# ===========================================
# Uncomment and modify for development environment

# NODE_ENV=development
# LOG_LEVEL=debug
# SERVER_LIST_INTERVAL_MS=3600000  # 1 hour in development
# DATA_COLLECTION_INTERVAL_MS=300000  # 5 minutes
# COLLECTION_CONCURRENCY=4  # Lower concurrency for development
# CORS_ORIGIN=http://localhost:5173  # Vite dev server
