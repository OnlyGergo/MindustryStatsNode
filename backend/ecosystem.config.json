{
  "apps": [
    {
      "name": "server-discovery",
      "script": "./dist/backend/src/services/server-discovery.js",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "200M",
      "env": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "SERVER_LIST_INTERVAL_MS": "86400000"
      },
      "env_development": {
        "NODE_ENV": "development",
        "LOG_LEVEL": "debug",
        "SERVER_LIST_INTERVAL_MS": "3600000"
      },
      "error_file": "./logs/server-discovery-error.log",
      "out_file": "./logs/server-discovery-out.log",
      "log_file": "./logs/server-discovery-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    },
    {
      "name": "server-collector",
      "script": "./dist/backend/src/services/server-collector.js",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "300M",
      "env": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "COLLECTION_CONCURRENCY": "8",
        "MINDUSTRY_TIMEOUT_MS": "1000",
        "QUEUE_POLL_TIMEOUT": "5"
      },
      "env_development": {
        "NODE_ENV": "development",
        "LOG_LEVEL": "debug",
        "COLLECTION_CONCURRENCY": "4",
        "MINDUSTRY_TIMEOUT_MS": "1000",
        "QUEUE_POLL_TIMEOUT": "5"
      },
      "error_file": "./logs/server-collector-error.log",
      "out_file": "./logs/server-collector-out.log",
      "log_file": "./logs/server-collector-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    },
    {
      "name": "server-processor",
      "script": "./dist/backend/src/services/server-processor.js",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "400M",
      "env": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "MAX_HISTORY_HOURS": "36",
        "MAX_HISTORY_POINTS": "864",
        "QUEUE_POLL_TIMEOUT": "5"
      },
      "env_development": {
        "NODE_ENV": "development",
        "LOG_LEVEL": "debug",
        "MAX_HISTORY_HOURS": "24",
        "MAX_HISTORY_POINTS": "288",
        "QUEUE_POLL_TIMEOUT": "5"
      },
      "error_file": "./logs/server-processor-error.log",
      "out_file": "./logs/server-processor-out.log",
      "log_file": "./logs/server-processor-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    },
    {
      "name": "api-service",
      "script": "./dist/backend/src/services/api-service.js",
      "instances": 2,
      "exec_mode": "cluster",
      "watch": false,
      "max_memory_restart": "250M",
      "env": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "API_PORT": "3000",
        "CORS_ORIGIN": "*"
      },
      "env_development": {
        "NODE_ENV": "development",
        "LOG_LEVEL": "debug",
        "API_PORT": "3000",
        "CORS_ORIGIN": "http://localhost:5173"
      },
      "error_file": "./logs/api-service-error.log",
      "out_file": "./logs/api-service-out.log",
      "log_file": "./logs/api-service-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    },
    {
      "name": "websocket-service",
      "script": "./dist/backend/src/services/websocket-service.js",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "max_memory_restart": "250M",
      "env": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "WS_PORT": "3001",
        "WS_PATH": "/ws",
        "CORS_ORIGIN": "*"
      },
      "env_development": {
        "NODE_ENV": "development",
        "LOG_LEVEL": "debug",
        "WS_PORT": "3001",
        "WS_PATH": "/ws",
        "CORS_ORIGIN": "http://localhost:5173"
      },
      "error_file": "./logs/websocket-service-error.log",
      "out_file": "./logs/websocket-service-out.log",
      "log_file": "./logs/websocket-service-combined.log",
      "time": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s"
    }
  ]
}

